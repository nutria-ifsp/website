---
import CardPlanos from '../components/CardPlanos.astro';
import CardEquipe from '../components/CardEquipe.astro';

import '../css/main.css';
import '../css/navbar.css';
import '../css/hero.css';
import '../css/features.css';
import '../css/banner.css';
import '../css/carousel.css';
import '../css/plans.css';
import '../css/team.css';
import '../css/components.css';
import '../css/footer.css';

---

<!--
==========================================================
   CABEÇALHO (metatags, título da página, favicon e CSS)
==========================================================
-->
<!--#region-->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nutria</title>

    <link rel="icon" type="image/svg+xml" href="/website/public/img/favicon.svg">
</head>
<!--#endregion-->

<body>
<!--
===================================================
   NAVBAR (logo, navlinks, troca tema e download)
===================================================
-->
<!--#region-->
    <nav class="navbar">
        <div class="nav-container">
            
            <div class="logo">
                <a href="https://nutria-ifsp.github.io/website/">
                     <img src="/website/public/img/N-logo.svg" alt="Logo Nutria">
                </a>
            </div>
            
            <ul class="nav-links">
                <li><a href="#funcoes">Funções</a></li>
                <li><a href="#planos">Planos</a></li>
                <li><a href="#equipe">Equipe</a></li>
            </ul>

            <div class="nav-actions">
                <button id="themeToggle" class="btn-theme" aria-label="Alternar Tema">
                    <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                    </svg>
                    <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="5"></circle>
                        <line x1="12" y1="1" x2="12" y2="3"></line>
                        <line x1="12" y1="21" x2="12" y2="23"></line>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                        <line x1="1" y1="12" x2="3" y2="12"></line>
                        <line x1="21" y1="12" x2="23" y2="12"></line>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                    </svg>
                </button>
                <button class="btn-download download-trigger">Baixe agora</button>
            </div>
            
        </div>
    </nav>
<!--#endregion-->





<!--
=====================================
   HERO (título, download e termos)
=====================================
-->
<!--#region-->
    <main class="main-content">
        
        <section class="hero">
            <h1 class="hero-title">
                Mantenha e compartilhe<br>uma alimentação saudável
            </h1>
            <p class="hero-subtitle">
                Encontre uma comunidade e desenvolva<br>sua rotina com saúde e motivação
            </p>
            <div class="hero-actions">
                <button class="hero-btn download-trigger">Baixe agora (00 MB)</button>
                <p class="hero-terms">
                    Ao baixar, você concorda com nossos <a href="termos.pdf" target="_blank">termos e condições</a>
                </p>
            </div>
        </section>
<!--#endregion-->





<!--
============================================
   FEATURES (benefícios em lista e imagem)
============================================
--> 
<!--#region-->
        <section class="features" id="funcoes">
            <div class="features-wrapper">
                <div class="features-text">
                    <h2 class="features-title">
                        O ambiente digital perfeito<br>para a sua alimentação
                    </h2>
                    <ul class="features-list">
                        <li>Poste suas receitas e dietas</li>
                        <li>Rotinas personalizadas para seu objetivo</li>
                        <li>Trilhe sozinho ou em grupos</li>
                        <li>Motive-se com nosso sistema de ofensiva</li>
                    </ul>
                    <h3 class="features-subtitle">
                        Tudo que você precisa, um só lugar.
                    </h3>
                </div>
                <div class="features-image">
                    <img src="/website/public/img/celular.svg" alt="Aplicativo Nutria no Celular">
                </div>
            </div>
        </section>
<!--#endregion-->





<!--
=======================================
   FAIXA/BANNER (banner preto visual)
=======================================
-->
<!--#region-->
        <section class="black-banner">
            <h2 class="banner-title">
                O aplicativo ideal para quem<br>busca novos começos.
            </h2>
        </section>
        
    </main>
<!--#endregion-->





<!--
=====================================
   PLANOS (assinaturas + carrossel)
=====================================
-->
<!--#region-->
<h2 class="plans-title">Nossos futuros planos</h2>    

<div class="plans-container" id="planos">
                    
    <CardPlanos nomeDoPlano="Básico">
        <div slot="icone">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </div>
        <div slot="features">
            <li><svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Limite de 4 postagens</li>
            <li><svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Limite de 1 grupo</li>
            <li class="disabled-feature"><svg class="cross-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>Análise de macros com IA</li>
        </div>
    </CardPlanos>
    
    <CardPlanos nomeDoPlano="Premium" classeDestaque="premium">
        <div slot="icone">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </div>
        <div slot="features">
            <li><svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Postagens ilimitadas</li>
            <li><svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Grupos ilimitados</li>
            <li><svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Análise de macros com IA</li>
        </div>
    </CardPlanos>
    
    <CardPlanos nomeDoPlano="Business" classeDestaque="business">
        <div slot="icone">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
        </div>
        <div slot="features">
            <li><svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Vantagens do Premium</li>
            <li><svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Melhores valores</li>
            <li><svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Grupos empresariais</li>
        </div>
    </CardPlanos>

    </div> 

    <div class="carousel-controls">
        <button id="btn-prev" aria-label="Plano Anterior">❮</button>
        <button id="btn-next" aria-label="Próximo Plano">❯</button>
    </div>
<!--#endregion-->



<!--
=====================================
   NOSSA EQUIPE (fotos + carrossel)
=====================================
-->
<!--#region-->
<section class="team" id="equipe">
    <h2 class="team-title">Nossa Equipe</h2>

    <div class="team-container">
        <CardEquipe nome="Matheus" cargo="Líder | Desenvolvedor" foto="/website/public/img/matheus.png" />
        <CardEquipe nome="Diego" cargo="Desenvolvedor" foto="/website/public/img/diego.png" />
        <CardEquipe nome="Dominique" cargo="Assistente de projeto" foto="/website/public/img/dominique.png" />
        
        <CardEquipe nome="Mario" cargo="Designer" foto="/website/public/img/mario.png" />
        <CardEquipe nome="Chantal" cargo="Assistente de projeto" foto="/website/public/img/chantal.png" />
    </div>
</section>
<!--#endregion-->





<!--
=================================================
   UTILITÁRIOS E MODAL (botão de topo e modais)
=================================================
-->
<!--#region-->
    <button id="btnScrollTop" class="btn-scroll-top" aria-label="Voltar ao topo">
        <svg width="26" height="22" viewBox="0 0 24 24" fill="#D1D5DB" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 4L24 20H0L12 4Z" />
        </svg>
    </button>

    <div id="qrModal" class="modal-overlay">
        <div class="modal-content">
            <button id="closeModal" class="btn-close-modal" aria-label="Fechar">&times;</button>
            <h3 class="modal-title">Baixe no seu celular</h3>
            <p class="modal-text">Escaneie o QR Code abaixo para iniciar o download do Nutria em seu celular.</p>
            <div class="qr-placeholder">
                <img src="/website/public/img/qrcode.png" alt="QR Code para download do APK" id="qrImage">
            </div>
        </div>
    </div>

    <div id="iosModal" class="modal-overlay">
        <div class="modal-content">
            <button id="closeIosModal" class="btn-close-modal" aria-label="Fechar">&times;</button>
            <h3 class="modal-title">Sentimos Muito :(</h3>
            <p class="modal-text">No momento, o aplicativo Nutria está disponível apenas para dispositivos Android.</p>
        </div>
    </div>
<!--#endregion-->


<!--
=================================================
   RODAPÉ (rodapé)
=================================================
-->
<!--#region-->

<footer class="footer-banner">
    <div class="footer-container">
        <p class="footer-text">© 2026 Nutria. Todos os direitos reservados.</p>
    </div>
</footer>
<!--#endregion-->



<!--
========================================
   SCRIPTS (importação dos javascripts)
========================================
-->
<!--#region-->
    <script src="../js/theme.js"></script>
    <script src="../js/scrollTop.js"></script>
    <script src="../js/downloadModals.js"></script>
    <script src="../js/carouselPlans.js"></script>
<!--#endregion-->

</body>
</html>